<?xml version="1.0" encoding="UTF-8"?>
<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="IEQ App" id="id-e793ba0c4d1048ad9af692f0e3a0a3a0" version="5.0.0">
  <folder name="Strategy" id="id-ca9949279472435e927f2c419265a25d" type="strategy"/>
  <folder name="Business" id="id-a4b9cb14d0e24113bb491afa61f316c9" type="business"/>
  <folder name="Application" id="id-7e4ec267d836411799b6194fc50401c3" type="application"/>
  <folder name="Technology &amp; Physical" id="id-719df6b698bc43f6bdfdd46e27a7ed3b" type="technology"/>
  <folder name="Motivation" id="id-d6f3dce43fb84b15ac2d1f314c0c87bc" type="motivation">
    <folder name="Stakeholders" id="id-a83e4817d71e4c1c83b8a96fe7dab1f2">
      <element xsi:type="archimate:Stakeholder" name="Obyvatel budovy" id="id-4ab5edefc1804e00b9673f516752ef49">
        <documentation>Osoba trávící čas v monitorovaném prostoru; zájem: znát aktuální a historický stav kvality vnitřního prostředí.</documentation>
      </element>
      <element xsi:type="archimate:Stakeholder" name="Správce budovy" id="id-75ccbd691e5a4b1eb4da257dd0ecaa12">
        <documentation>Osoba zodpovědná za provoz a údržbu budovy; zájem: monitoring prostředí a sledování historických trendů IEQ.</documentation>
      </element>
      <element xsi:type="archimate:Stakeholder" name="Výrobce HVAC" id="id-2dad762adf7c48029fe5100e9890e475">
        <documentation>Výrobce topných, ventilačních a klimatizačních systémů; zájem: reálná data pro vývoj a optimalizaci produktů.</documentation>
      </element>
      <element xsi:type="archimate:Stakeholder" name="Vývojář třetí strany" id="id-f9c1b143bee74dbf8751dcbc7ac5cbce">
        <documentation>Vývojář integrující se přes API; zájem: stabilní, verzované a zdokumentované rozhraní umožňující spolehlivou integraci.</documentation>
      </element>
      <element xsi:type="archimate:Stakeholder" name="Výzkumný pracovník" id="id-7631466ffb364d098cc8aa85f6514e2e">
        <documentation>Akademik nebo vědec využívající otevřená IEQ data pro výzkum vlivu prostředí na zdraví a produktivitu.</documentation>
      </element>
    </folder>
    <folder name="Drivers" id="id-ab8466e8d9f247ce9ee0182f3073ba95">
      <element xsi:type="archimate:Driver" name="Dopad IEQ na zdraví a produktivitu" id="id-637200b0ec7a432bb2861adf890af35b">
        <documentation>Znečištění vnitřního ovzduší přispívá k předčasným úmrtím a snižuje pracovní výkonnost; motivuje ke sběru a sdílení IEQ dat.</documentation>
      </element>
      <element xsi:type="archimate:Driver" name="Fragmentovanost trhu IoT senzorů" id="id-f69b3e0d367d4ed5924171f71fa2d7c7">
        <documentation>Různí výrobci používají nekompatibilní protokoly a datové formáty; bez jednotného rozhraní je integrace senzorů nákladná.</documentation>
      </element>
      <element xsi:type="archimate:Driver" name="Nedostupnost standardizovaných otevřených IEQ dat" id="id-757962516f9243c1b876ba623579a580">
        <documentation>V České republice chybí veřejná, strojově čitelná a standardizovaná datová platforma pro IEQ umožňující opakované použití.</documentation>
      </element>
      <element xsi:type="archimate:Driver" name="Trend otevřených dat" id="id-4533d015a3ab45f783bcefc0dfdeeca8">
        <documentation>Evropská (EU Open Data Directive) a česká legislativa prosazují publikaci dat jako otevřených a strojově čitelných.</documentation>
      </element>
    </folder>
    <folder name="Assessments" id="id-8c82a147acb140098fb693e11925b5de">
      <element xsi:type="archimate:Assessment" name="Absence formálního datového modelu pro IEQ" id="id-8fd77d1627b849fda6c9105c9c484e21">
        <documentation>Neexistuje standardizovaný otevřený datový model pro publikaci IEQ měření kompatibilní s DCAT-AP a OFN.</documentation>
      </element>
      <element xsi:type="archimate:Assessment" name="Existující IEQ jsou OFN nekonformní" id="id-185cecf2ee8d40bf9dcb7d8724cbed12">
        <documentation>Čistě IEQ (open source) řešení se na trhu vůbec nevyskutuje. Existují řešení podporující určité parametry IEQ, ale o těchto řešeních lze říci, že nejsou zcela konformní s OFN a tedy zákonem 106/1999 Sb.</documentation>
      </element>
      <element xsi:type="archimate:Assessment" name="Fyzikální veličiny jsou objektivně měřitelné" id="id-b9e20240f2154bf0a1b3e6d05fd012d6">
        <documentation>TODO: doplnit veličiny</documentation>
      </element>
      <element xsi:type="archimate:Assessment" name="Projekt nesplňuje podmínky NKOD a DCAT-AP-CZ" id="id-d1d6599acaec412b8ffb579344919720">
        <documentation>Projekt není orgánem veřejné moci, takže registrace v NKOD a plná implementace DCAT-AP-CZ jsou nerealizovatelné.</documentation>
      </element>
    </folder>
    <folder name="Goals" id="id-a88d27f408814857a0b9f6d8a6e8b484">
      <element xsi:type="archimate:Goal" name="Zpřístupnit IEQ data jako otevřená data" id="id-bbe48089735c4b458c05bf61634f5a2d">
        <documentation>Naměřená data publikovat veřejně v otevřených formátech pod otevřenou licencí, aby je mohl kdokoliv volně číst a znovu použít.</documentation>
      </element>
      <element xsi:type="archimate:Goal" name="Zajistit interoperabilitu s různými senzory" id="id-ee7fe8ab70f140d988d5702167b1541e">
        <documentation>Umožnit napojení libovolného typu senzoru bez závislosti na konkrétním výrobci nebo protokolu.</documentation>
      </element>
      <element xsi:type="archimate:Goal" name="Soulad s evropskými standardy otevřených dat" id="id-025fc793b7f34570a2b07eb8ce87b10b">
        <documentation>Metadatový model, formáty a licence musí odpovídat specifikaci DCAT-AP 3.0 a relevantním OFN.</documentation>
      </element>
    </folder>
    <folder name="Outcomes" id="id-bef87abe4d3941188088d27f82475b99">
      <element xsi:type="archimate:Outcome" name="Veřejně dostupný dataset IEQ měření" id="id-70a3d301b84e46d59f1c3773f84f6efc">
        <documentation>Otevřený dataset přístupný přes čtecí REST API a archivní exporty ke stažení; opakovaně použitelný bez registrace.</documentation>
      </element>
      <element xsi:type="archimate:Outcome" name="Znovupoužitelný open-source kód" id="id-0602a0ed7b884636b7af5b68370407a1">
        <documentation>Zdrojový kód uveřejněný ve veřejném repozitáři pod open-source licencí umožňující komunitní rozvoj a adaptaci.</documentation>
      </element>
      <element xsi:type="archimate:Outcome" name="Standardizovaný a validovatelný datový model" id="id-0c5fffea612c45468bfd9f715acfbb63">
        <documentation>Formální schéma dat (JSON Schema) a verzované JSON-LD kontexty zajišťující sémantickou interoperabilitu a automatizovanou validaci.</documentation>
      </element>
    </folder>
    <folder name="Principles" id="id-6f5a0b6c765047a888377d60532f6194">
      <element xsi:type="archimate:Principle" name="Otevřenost dat" id="id-dd5b325a51fa45e1bc13426129166ed9">
        <documentation>Veškerá publikovaná data jsou dostupná v otevřených formátech (JSON-LD, CSV UTF-8) pod otevřenou licencí (CC BY 4.0); proprietární formáty se nepoužívají.</documentation>
      </element>
      <element xsi:type="archimate:Principle" name="Nezávislost na výrobci" id="id-eb5daff0fa764001bf26f5e40708a599">
        <documentation>Systém nesmí být závislý na konkrétním výrobci nebo typu senzoru; integrace každého zařízení se realizuje přes jednotné aplikační rozhraní.</documentation>
      </element>
      <element xsi:type="archimate:Principle" name="Zpětná kompatibilita rozhraní" id="id-12db86f14dbb41b6a026a2094c7967bd">
        <documentation>Nekompatibilní změna API nebo JSON-LD kontextu vyžaduje zavedení nové verze; stávající integrace a použití dat nesmí být narušeny.</documentation>
      </element>
      <element xsi:type="archimate:Principle" name="Objektivnost a ověřitelnost dat" id="id-e12266114b6f42658babfa28289b4dca">
        <documentation>Systém eviduje výhradně faktory IEQ měřitelné senzoricky nebo jednoznačně evidovatelné; subjektivní veličiny jsou mimo rozsah.</documentation>
      </element>
    </folder>
    <folder name="Requirements" id="id-eb5651c0da094ef6a9932a88c9eb2df8">
      <folder name="Functional" id="id-26474508626c424fbdb62c4746b2541c">
        <documentation>Funční požadavky aplikace</documentation>
        <element xsi:type="archimate:Requirement" name="F01 Kompletní veličiny IEQ" id="id-29e96262ecf14c1c9166a2b81ce95cf5">
          <documentation>Systém musí evidovat a publikovat minimálně data veličin CO₂, PM₂.₅, PM₁₀, TVOC, teploty, relativní vlhkosti, rychlosti proudění vzduchu, osvětlenosti a hladiny akustického tlaku; je-li měření dostupné, také CCT, NO₂, SO₂, CO a O₃.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="F02 Evidence měřicích bodů" id="id-4d3b3c3e5563498ebca24b807659e2ce">
          <documentation>Systém musí evidovat každý měřicí bod jako samostatný zdroj dat s jednoznačným identifikátorem, polohou a základním kontextem umístění.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="F03 Zpřístupnění dat ke čtení" id="id-f118dac45ec4455f9af2c86885ea3fa1">
          <documentation>Systém musí zpřístupňovat aktuální i historická data pro strojové čtení a opakované použití.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="F04 Mapová vizualizace dat" id="id-0184c17344e94b73b050d649a2bf689e">
          <documentation>Systém musí zobrazovat měřicí body a jejich aktuální hodnoty v interaktivní mapě.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="F05 Filtrování dat" id="id-f8913fe1599944408accde152824a656">
          <documentation>Systém musí umožnit filtrování dat podle veličiny, senzoru a časového období.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="F06 Historie měření" id="id-b41506c2c63f455ba40618d40b3a7050">
          <documentation>Systém musí zobrazovat historický průběh měření vybraného bodu nebo veličiny v grafické podobě.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="F07 Evidence metadat senzoru" id="id-99b2a7c769684ebda01740708bdbae0c">
          <documentation>Systém musí u měřicího bodu zveřejňovat model senzoru, podporované veličiny a dostupné údaje o přesnosti nebo charakteru měření.</documentation>
        </element>
      </folder>
      <folder name="Usability" id="id-dec76ec2dba34a9389ebb5e3534c5688">
        <documentation>Nefunční požadaveky použitelnosti</documentation>
        <element xsi:type="archimate:Requirement" name="POU01 Jednotné názvy veličin" id="id-bcab18103933480d9db52606cb2b693d">
          <documentation>Stejná veličina musí být v uživatelském rozhraní i exportech vždy označena stejným názvem, značkou a jednotkou.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="POU02 Přístup přes webový prohlížeč" id="id-c3d5f9a8494b49dba52bb9a2857921ed">
          <documentation>Primární uživatelské rozhraní musí být plně použitelné v běžném moderním webovém prohlížeči bez instalace specializovaného klienta.</documentation>
        </element>
      </folder>
      <folder name="Reliability" id="id-82a434a9dc6945449a41b3c87869deaa">
        <documentation>Stejné měření musí být v API i archivech vedeno pod shodným identifikátorem bodu, názvem veličiny, jednotkou a časovým údajem.</documentation>
        <element xsi:type="archimate:Requirement" name="SPO01 Nezveřejňovat neúplné záznamy" id="id-c9e8354629044535895979697ac84c3d">
          <documentation>Záznam měření nesmí být zveřejněn, pokud chybí identifikátor měřicího bodu, čas měření, veličina, hodnota nebo vazba na polohu.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="SPO02 Konzistence napříč výstupy" id="id-f702d69aa25f4f17aa909456087315a2"/>
        <element xsi:type="archimate:Requirement" name="SPO03 Obnovitelné zálohy dat" id="id-b938323fea6f4f9b9448f181cdc0515c">
          <documentation>Každá publikovaná verze archivu a aktuální stav databáze musí mít samostatnou obnovitelnou zálohu, aby ztráta pracovní kopie neznamenala ztrátu dat.</documentation>
        </element>
      </folder>
      <folder name="Performance" id="id-5b28478a08754a788798228f299bff04">
        <element xsi:type="archimate:Requirement" name="VYK01 Optimalizace častých dotazů" id="id-3e81ae2c107d4e79befba3afabe49961">
          <documentation>Čtecí operace nad mapou, historií měření a archivem musí být realizovány nad indexovanými nebo cacheovanými daty.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="VYK02 Průběžné zpracování dat" id="id-a1aa64a70119473dbc6e513ad63caf3e">
          <documentation>Systém musí zpracovávat nová měření průběžně, bez ručně spouštěného dávkového importu.</documentation>
        </element>
      </folder>
      <folder name="Supportability" id="id-16ed6f02e4c848cb9bd7739da2317dc9">
        <documentation>Zdrojový kód aplikace musí být dostupný ve veřejném repozitáři pod licencí kompatibilní s Open Source Definition.</documentation>
        <element xsi:type="archimate:Requirement" name="POD01 Veřejný repozitář kódu" id="id-869752dcc1244490b8123676afe87403"/>
        <element xsi:type="archimate:Requirement" name="POD02 Řízený katalog veličin" id="id-e2e524fe29b44b5a876d003202c755ea">
          <documentation>Nová veličina musí být přidávána rozšířením centrálního katalogu veličin a jednotek, nikoli zavedením ad hoc názvu v datech.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="POD03 Rozšiřitelná integrace zařízení" id="id-499b68fe5709479b8f43a25eed094863">
          <documentation>Napojení nového zařízení musí být možné bez změny významu stávajících veličin a bez porušení kompatibility publikovaných dat.</documentation>
        </element>
      </folder>
      <folder name="Interface" id="id-989c28c4222b4da2a0855c85cb66ff76">
        <documentation>Systém musí přijímat měření přes verzované HTTPS REST API se strojově čitelným formátem JSON; nekompatibilní změna vyžaduje novou verzi rozhraní.</documentation>
        <element xsi:type="archimate:Requirement" name="ROZ01 Verzované vstupní REST API" id="id-2da0183df8c246f9b540c546e03a33ae"/>
        <element xsi:type="archimate:Requirement" name="ROZ02 Verzované čtecí REST API" id="id-730d9ffc18524e1993b3d57a86fc9954">
          <documentation>Systém musí poskytovat veřejné čtecí verzované REST API přes HTTPS a JSON bez nutnosti registrace nebo API klíče pro čtení.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="ROZ03 Archivní export přes HTTPS" id="id-4b64fc8d31ee4387a7a2bf1b31756008">
          <documentation>Systém musí zpřístupňovat archivní exporty dat ke stažení přes HTTPS v otevřeném formátu určeném pro opakované použití.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="ROZ04 Integrace různých zařízení" id="id-ef67fca0e9614d9aa034d04577dab8cd">
          <documentation>Externí zařízení musí být integrována přes převod na jednotné aplikační rozhraní, bez závislosti na jediném výrobci nebo typu senzoru.</documentation>
        </element>
      </folder>
      <folder name="Standards" id="id-cac653432afd4b3ba96d887a6cf41c7a">
        <documentation>Publikovaná data musí být dostupná v otevřeném a strojově čitelném formátu; preferován je JSON-LD, alternativně CSV v kódování UTF-8. Proprietární formáty se nepoužijí.</documentation>
        <element xsi:type="archimate:Requirement" name="STA01 Otevřené formáty dat" id="id-7235443003154747b2a890be3f2f797c"/>
        <element xsi:type="archimate:Requirement" name="STA02 Metadata dle DCAT-AP 3.07" id="id-8ac1fd94175448d9a2029eca49ab8649">
          <documentation>Metadata datasetů, distribucí a datových služeb musí odpovídat specifikaci DCAT-AP 3.0 v rozsahu relevantním pro projekt.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="STA03 Otevřená licence dat" id="id-1b3c7075096648f4b6b3ac18065f6e94">
          <documentation>Každý dataset musí mít explicitně uvedenou otevřenou licenci umožňující opakované použití; preferována je CC BY 4.0.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="STA04 OFN pro umístění" id="id-d484f4ca15094435af579aa77a539898">
          <documentation>Poloha měřicích bodů musí být publikována jako geometrický objekt podle OFN pro umístění, nikoli jen jako dvojice atributů zeměpisné šířky a délky.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="STA05 OFN pro čas" id="id-fb939287788447a5870ae16ed638a5eb">
          <documentation>Časové údaje musí být zapisovány podle OFN pro časovou specifikaci ve formátu ISO 8601 včetně časové zóny.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="STA06 OFN pro datové typy" id="id-3e190e7550bc4e53925187ea4db1f8b0">
          <documentation>Číselné veličiny musí být publikovány jako číselné datové typy, nikoli jako textové řetězce; ostatní hodnoty musí respektovat odpovídající základní datové typy OFN.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="STA07 Formální schéma dat" id="id-c604f09189724afe9f5bedc2600017b2">
          <documentation>Pro publikovaná data musí existovat formální schéma (JSON Schema nebo schéma pro CSV) umožňující automatizovanou validaci.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="STA08 Verzované JSON-LD kontexty" id="id-4c0b64be36844494a995531a78a30d5c">
          <documentation>Každý publikovaný JSON-LD kontext musí mít stabilní verzované IRI; nekompatibilní změna významu termínů vyžaduje novou verzi kontextu.</documentation>
        </element>
      </folder>
      <folder name="Documentaition" id="id-492d01cd762249018499304b01812b63">
        <element xsi:type="archimate:Requirement" name="DOK01 HTML dokumentace rozhraní" id="id-ae2c3dc0c1e545dc90c72e27ecae7368">
          <documentation>K API, archivům a datasetům musí existovat veřejně dostupná HTML dokumentace popisující účel, způsob použití, verzi a základní parametry.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="DOK02 Popis datového modelu" id="id-8365ffccab3d453aace46ca1b4296061">
          <documentation>Dokumentace musí popisovat význam polí, jednotky, datové typy a vazbu na formální schémata, metadata a JSON-LD kontexty.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="DOK03 Dokumentace senzorů" id="id-1adbd67802db4f60b060a59058fc51b7">
          <documentation>Dokumentace musí uvádět používané senzory nebo typy zařízení, jejich měřené veličiny a dostupné údaje o přesnosti.</documentation>
        </element>
        <element xsi:type="archimate:Requirement" name="DOK04 Dokumentace umístění čidel" id="id-cd09bbb8e46c4244949854b0eccd1c85">
          <documentation>Pokud jsou údaje dostupné, dokumentace musí popisovat umístění čidel, zejména výšku, orientaci a další okolnosti ovlivňující interpretaci měření.</documentation>
        </element>
      </folder>
    </folder>
    <folder name="Constraints" id="id-48fd1ad40aa2438982f03907aa59e94e">
      <element xsi:type="archimate:Constraint" name="Projekt není orgánem veřejné moci" id="id-03c57758cf1e4175a42c723cd2dc515b">
        <documentation>Řešení nesmí být závislé na registraci v NKOD ani na implementaci DCAT-AP-CZ, protože projekt není orgánem veřejné moci ve smyslu zákona č. 106/1999 Sb. (SYS01, SYS02).</documentation>
      </element>
      <element xsi:type="archimate:Constraint" name="Rozsah omezen na objektivně měřitelné faktory IEQ" id="id-b69f27165924411488538d146197b229">
        <documentation>Systém eviduje výhradně faktory IEQ, které lze rozumně získat senzoricky; subjektivní veličiny (soukromí, výhled, design budovy) jsou mimo rozsah (SYS03).</documentation>
      </element>
      <element xsi:type="archimate:Constraint" name="Omezení zdrojů akademické práce" id="id-61200401171e491abc665e352fbbf502">
        <documentation>Dostupné časové a finanční zdroje jsou omezeny rámcem bakalářské práce; volba technologií a rozsah implementace tomu odpovídají.</documentation>
